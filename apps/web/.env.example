# Database
# Used by @benkyou/db for Drizzle queries and migrations.
# For Docker Compose, use the root .env.example as the canonical template.
DATABASE_URL=

# Auth
# Generate with: npx -y @better-auth/cli secret
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Public canonical URL for SEO metadata, robots.txt, and sitemap.xml.
PUBLIC_SITE_URL=http://localhost:3000

# Optional PostHog analytics. Leave blank to disable analytics for self-hosting.
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
VITE_PUBLIC_POSTHOG_DISABLED=false
VITE_PUBLIC_POSTHOG_ENABLE_IN_DEVELOPMENT=false

# AI generation
# Keep provider keys server-side. Do not expose or commit real values.
AI_PROVIDER=openai
AI_API_KEY=
OPENAI_MODEL=

# YouTube transcript fetching
# auto uses TranscriptAPI when TRANSCRIPTAPI_API_KEY is set, otherwise the free
# local youtube-transcript package. Use transcriptapi for hosted production.
YOUTUBE_TRANSCRIPT_PROVIDER=auto
TRANSCRIPTAPI_API_KEY=

YOUTUBE_API_KEY=

# Course generation rate limit
# Defaults protect self-hosted AI usage without requiring configuration.
GENERATION_RATE_LIMIT_MAX=5
GENERATION_RATE_LIMIT_WINDOW_HOURS=24
