{
  "name": "@benkyou/ui",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "format": "prettier --check \"src/**/*.{ts,tsx}\"",
    "lint": "eslint . --max-warnings 0",
