{
  "name": "@benkyou/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:check": "drizzle-kit check --config=drizzle.config.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "test": "vitest run --pool=threads --passWithNoTests"
  },
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.43.1",
    "pg": "^8.13.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.30.6",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
