# Self-hosting environment template.
# Copy this file to .env before running Docker Compose:
#   cp .env.example .env
#
# .env is local-only and should stay gitignored. Never commit real values for
# POSTGRES_PASSWORD, BETTER_AUTH_SECRET, AI_API_KEY, or other provider secrets.

# Docker Compose database settings. Postgres is reachable by the web container
# at the internal hostname "db" and is not published on the host by default.
POSTGRES_DB=benkyou
POSTGRES_USER=benkyou
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Host port for the web app. The container always listens on 3000.
BENKYOU_WEB_PORT=3000

# Public canonical URL for SEO metadata, robots.txt, and sitemap.xml.
PUBLIC_SITE_URL=http://localhost:3000

# Local Node/pnpm development only. Docker Compose builds DATABASE_URL from the
# POSTGRES_* values above so the container can reach postgres://...@db:5432/...
DATABASE_URL=postgres://benkyou:replace-with-a-long-random-password@localhost:5432/benkyou

# Auth
# Generate with: npx -y @better-auth/cli secret
BETTER_AUTH_SECRET=replace-with-a-long-random-auth-secret
BETTER_AUTH_URL=http://localhost:3000

# AI generation. Set AI_API_KEY before enabling real generation in production.
AI_PROVIDER=openai
AI_API_KEY=
OPENAI_MODEL=

# Optional YouTube metadata enrichment.
YOUTUBE_API_KEY=

# Course generation abuse protection.
GENERATION_RATE_LIMIT_MAX=5
GENERATION_RATE_LIMIT_WINDOW_HOURS=24
