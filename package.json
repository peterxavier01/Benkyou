{
  "name": "@benkyou/root",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "check": "turbo run check",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.8",
    "typescript": "5.9.2"
  },
  "pnpm": {
    "packageExtensions": {
      "vite-plugin-neon-new@*": {
        "peerDependencies": {
          "vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
        }
      }
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "vite-plugin-neon-new>vite": "^8.0.0"
      }
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.19"
  }
}
